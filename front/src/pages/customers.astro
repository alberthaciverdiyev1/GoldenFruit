---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Müşteri Yönetimi">
    <div class="ml-64 min-h-screen">
        <div class="p-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Müşteriler</h1>
                    <p class="text-slate-500 mt-1">Cari hesaplarını buradan yönetebilirsiniz.</p>
                </div>
                <button
                        onclick="openCustomerModal()"
                        class="bg-orange-500 text-white px-6 py-3 rounded-xl shadow-lg shadow-orange-200 hover:bg-orange-600 transition-all active:scale-95 font-semibold flex items-center gap-2"
                >
                    <i data-lucide="user-plus" class="w-5 h-5"></i>
                    Yeni Müşteri
                </button>
            </div>

            <div id="customer-container" class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-20 text-center">
                    <div class="animate-spin inline-block w-10 h-10 border-4 border-orange-500 border-t-transparent rounded-full mb-4"></div>
                    <p class="text-slate-400 animate-pulse">Veritabanına bağlanılıyor...</p>
                </div>
            </div>
        </div>
    </div>

    <div id="customer-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[100] flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden animate-in fade-in zoom-in duration-200">
            <div class="p-6 border-b border-slate-50 flex justify-between items-center bg-slate-50/50">
                <h3 id="modal-title" class="text-xl font-bold text-slate-800">Müşteri Formu</h3>
                <button onclick="closeCustomerModal()" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-200 text-slate-500 transition-colors">✕</button>
            </div>
            <form id="customer-form" class="p-8 space-y-5">
                <input type="hidden" id="customer-id" />
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Ad</label>
                    <input type="text" id="cust-name" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 outline-none transition-all" placeholder="Örn: Albert" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Soyad</label>
                    <input type="text" id="cust-surname" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 outline-none transition-all" placeholder="Örn: Haciverdiyev" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Telefon</label>
                    <input type="text" id="cust-phone" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 outline-none transition-all" placeholder="050-XXX-XX-XX" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Address</label>
                    <textarea id="cust-address" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 outline-none transition-all" placeholder="Baki seheri" />
                </div>
                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeCustomerModal()" class="flex-1 px-4 py-3 border border-slate-200 rounded-xl hover:bg-slate-50 font-bold text-slate-600 transition-colors">İptal</button>
                    <button type="submit" class="flex-1 px-4 py-3 bg-orange-500 text-white rounded-xl hover:bg-orange-600 font-bold shadow-lg shadow-orange-100 transition-all">Kaydet</button>
                </div>
            </form>
        </div>
    </div>

    <script is:inline src="/services/customer.js"></script>
</MainLayout>