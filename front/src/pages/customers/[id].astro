---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Müştəri Detalları">
    <div class="ml-64 min-h-screen bg-slate-50">
        <div class="p-8">
            <a href="/customers" class="text-orange-600 hover:underline mb-4 inline-block">&larr; Müştərilərə Qayıt</a>

            <div id="customerDetail" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Müştəri Kartı -->
                <div class="bg-white rounded-xl border shadow-sm p-6">
                    <div id="customerInfo" class="space-y-3">
                        <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center mb-4">
                            <i data-lucide="user" class="w-8 h-8 text-orange-600"></i>
                        </div>
                        <h2 id="detailName" class="text-2xl font-bold text-slate-800">-</h2>
                        <p id="detailPhone" class="text-slate-500"><span class="font-medium">Telefon:</span> -</p>
                        <p id="detailAddress" class="text-slate-500"><span class="font-medium">Ünvan:</span> -</p>
                        <p id="detailCreated" class="text-slate-400 text-sm"><span class="font-medium">Qeydiyyat:</span> -</p>
                    </div>
                    <div class="mt-6 pt-4 border-t">
                        <h3 class="font-semibold text-slate-700 mb-2">Cari Bakiye</h3>
                        <div id="balanceInfo" class="text-2xl font-bold text-green-600">0.00 AZN</div>
                    </div>
                </div>

                <!-- Satışlar & Alışlar Geçmişi -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Satışlar -->
                    <div class="bg-white rounded-xl border shadow-sm">
                        <div class="px-6 py-4 border-b bg-slate-50 flex justify-between items-center">
                            <h3 class="font-bold text-slate-800">Satışlar</h3>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-slate-100">
                                    <tr>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Tarix</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Növ</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Miqdar</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Məbləğ</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Çəki</th>
                                    </tr>
                                </thead>
                                <tbody id="customerSales"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Alışlar -->
                    <div class="bg-white rounded-xl border shadow-sm">
                        <div class="px-6 py-4 border-b bg-slate-50 flex justify-between items-center">
                            <h3 class="font-bold text-slate-800">Alışlar</h3>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-slate-100">
                                    <tr>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Tarix</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Miqdar</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Məbləğ</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Çəki</th>
                                    </tr>
                                </thead>
                                <tbody id="customerPurchases"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Avanslar -->
                    <div class="bg-white rounded-xl border shadow-sm">
                        <div class="px-6 py-4 border-b bg-slate-50 flex justify-between items-center">
                            <h3 class="font-bold text-slate-800">Avanslar</h3>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-slate-100">
                                    <tr>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Tarix</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Göndərən</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Məbləğ</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Ödəniş</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Borc</th>
                                    </tr>
                                </thead>
                                <tbody id="customerAdvances"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Balans Tarixçəsi -->
                    <div class="bg-white rounded-xl border shadow-sm">
                        <div class="px-6 py-4 border-b bg-slate-50">
                            <h3 class="font-bold text-slate-800">Balans Tarixçəsi</h3>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-slate-100">
                                    <tr>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Tarix</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Tip</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Məbləğ</th>
                                    </tr>
                                </thead>
                                <tbody id="customerBalanceHistory"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</MainLayout>

<script is:inline src="/services/customer.js"></script>
