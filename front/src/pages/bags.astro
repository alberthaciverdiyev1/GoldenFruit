---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Kaset İdarəetməsi">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet' slot="head" />

    <div class="ml-64 min-h-screen bg-slate-50/50">
        <div class="p-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800 tracking-tight flex items-center gap-3">
                        <i class='bx bx-archive text-indigo-600'></i>
                        Kaset Qeydiyyatı
                    </h1>
                    <p class="text-slate-500 mt-1 font-medium">Tədarük, geri qaytarılan və borc izləmə</p>
                </div>
                <button
                        onclick="openBagModal()"
                        class="bg-indigo-600 text-white px-6 py-3 rounded-2xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 transition-all active:scale-95 font-bold flex items-center gap-2"
                >
                    <i class='bx bx-plus-circle text-xl'></i>
                    Yeni Qeyd
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                    <p class="text-slate-500 text-xs font-black uppercase tracking-widest flex items-center gap-2">
                        <i class='bx bx-package text-indigo-500'></i> Cəmi Bağ
                    </p>
                    <h2 id="stat-total-bags" class="text-3xl font-black text-slate-800 mt-2">0</h2>
                </div>
                <div class="bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                    <p class="text-red-500 text-xs font-black uppercase tracking-widest flex items-center gap-2">
                        <i class='bx bx-money-withdraw'></i> Ümumi Borc
                    </p>
                    <h2 id="stat-total-debt" class="text-3xl font-black text-red-600 mt-2">0.00 AZN</h2>
                </div>
                <div class="bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                    <p class="text-emerald-600 text-xs font-black uppercase tracking-widest flex items-center gap-2">
                        <i class='bx bx-wallet'></i> Cəmi Ödəniş
                    </p>
                    <h2 id="stat-total-payment" class="text-3xl font-black text-emerald-600 mt-2">0.00 AZN</h2>
                </div>
            </div>

            <div id="bag-container" class="bg-white rounded-[2rem] shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-20 text-center">
                    <i class='bx bx-loader-alt animate-spin text-4xl text-indigo-600 mb-4 block'></i>
                    <p class="text-slate-400 font-medium">Məlumatlar yüklənir...</p>
                </div>
            </div>
        </div>
    </div>

    <div id="bag-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white rounded-[2.5rem] shadow-2xl w-full max-w-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
            <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <h3 id="modal-title" class="text-xl font-bold text-slate-800">Yeni Qeydiyyat</h3>
                <button onclick="closeBagModal()" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-slate-200 text-slate-400 transition-colors">
                    <i class='bx bx-x text-2xl'></i>
                </button>
            </div>
            <form id="bag-form" class="p-8">
                <input type="hidden" id="bag-id" />
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-600 ml-1">Tarix</label>
                        <input type="date" id="bag-date" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:border-indigo-500 outline-none font-medium transition-all" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-600 ml-1">Şəxs (Ad Soyad)</label>
                        <input type="text" id="bag-person" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:border-indigo-500 outline-none font-medium transition-all" placeholder="Bəhrəm..." />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-600 ml-1">Bağ Sayı</label>
                        <input type="number" id="bag-count" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:border-indigo-500 outline-none font-bold" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-600 ml-1">Geri Qaytarılan</label>
                        <input type="number" id="bag-returned" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:border-indigo-500 outline-none font-bold" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-600 ml-1">Qalıq Borc (AZN)</label>
                        <input type="number" step="0.01" id="bag-debt" class="w-full px-4 py-3 bg-rose-50 border border-rose-100 rounded-2xl focus:border-red-500 outline-none font-bold text-red-600" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-600 ml-1">Ödəniş (AZN)</label>
                        <input type="number" step="0.01" id="bag-payment" class="w-full px-4 py-3 bg-emerald-50 border border-emerald-100 rounded-2xl focus:border-emerald-500 outline-none font-bold text-emerald-700" />
                    </div>
                </div>
                <div class="mt-5 space-y-1">
                    <label class="text-xs font-bold text-slate-600 ml-1">Qeyd</label>
                    <textarea id="bag-note" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:border-indigo-500 outline-none" rows="2" placeholder="Əlavə məlumat..."></textarea>
                </div>
                <div class="flex gap-4 pt-6">
                    <button type="button" onclick="closeBagModal()" class="flex-1 px-4 py-4 border border-slate-200 rounded-2xl font-bold text-slate-500 hover:bg-slate-50 transition-all">Ləğv Et</button>
                    <button type="submit" class="flex-1 px-4 py-4 bg-indigo-600 text-white rounded-2xl font-black shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all">Yadda Saxla</button>
                </div>
            </form>
        </div>
    </div>

    <script is:inline src="/services/bags.js"></script>
</MainLayout>