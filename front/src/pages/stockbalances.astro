---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Stok Qalıqları">
    <div class="ml-64 min-h-screen bg-slate-50">
        <div class="p-8">
            <div class="flex justify-between items-center mb-6">
                <h1 class="text-2xl font-bold text-slate-800">Stok Qalıqları & Transferlər</h1>
                <button onclick="openStockModal()" class="bg-teal-500 text-white px-4 py-2 rounded-lg hover:bg-teal-600 transition-colors">+ Yeni Qeyd</button>
            </div>

            <div class="bg-white rounded-xl border shadow-sm overflow-hidden">
                <table class="w-full">
                    <thead class="bg-slate-100">
                        <tr>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Tarix</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Açıqlama</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Miqdar</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Net Çəki</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Məbləğ</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Əlaqəli Şəxs</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Qeyd</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody id="stockTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div id="stockModal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-2xl p-6 w-full max-w-lg mx-4 shadow-2xl">
            <h2 id="stockModalTitle" class="text-xl font-bold text-slate-800 mb-4">Yeni Stok Qalığı</h2>
            <form onsubmit="saveStockBalance(event)">
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Tarix</label>
                        <input type="date" id="stockDate" class="w-full border rounded-lg px-3 py-2" required>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Açıqlama</label>
                        <textarea id="stockDesc" class="w-full border rounded-lg px-3 py-2" rows="2" placeholder="2153 kq = 6780 manat peymandan..." required></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Miqdar (kaset)</label>
                        <input type="number" step="any" id="stockQty" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Net Çəki (kq)</label>
                        <input type="number" step="0.1" id="stockWeight" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Məbləğ (AZN)</label>
                        <input type="number" step="0.01" id="stockAmount" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Əlaqəli Şəxs</label>
                        <input type="text" id="stockPerson" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Qeyd</label>
                        <input type="text" id="stockNote" class="w-full border rounded-lg px-3 py-2">
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" onclick="closeStockModal()" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg">Ləğv et</button>
                    <button type="submit" class="px-4 py-2 bg-teal-500 text-white rounded-lg hover:bg-teal-600">Yadda saxla</button>
                </div>
            </form>
        </div>
    </div>
</MainLayout>

<script is:inline src="/services/stockbalance.js"></script>
