---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Kaset Detalları">
    <div class="ml-64 min-h-screen bg-slate-50">
        <div class="p-8">
            <a href="/bags" class="text-indigo-600 hover:underline mb-4 inline-block">&larr; Kasetlərə Qayıt</a>

            <div id="bagDetail" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Kaset Kartı -->
                <div class="bg-white rounded-xl border shadow-sm p-6">
                    <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mb-4">
                        <i data-lucide="archive" class="w-8 h-8 text-indigo-600"></i>
                    </div>
                    <h2 id="detailBagPerson" class="text-2xl font-bold text-slate-800">-</h2>
                    <div class="mt-4 space-y-3">
                        <div class="flex justify-between">
                            <span class="text-slate-500">Tarix:</span>
                            <span id="detailBagDate" class="font-semibold text-slate-800">-</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-500">Verilən Kaset:</span>
                            <span id="detailBagCount" class="font-semibold text-slate-800">-</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-500">Geri Qaytarılan:</span>
                            <span id="detailBagReturned" class="font-semibold text-slate-800">-</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-500">Qaytarılmalı:</span>
                            <span id="detailBagToReturn" class="font-semibold text-red-600">-</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-500">Borc (AZN):</span>
                            <span id="detailBagDebt" class="font-semibold text-red-600">- AZN</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-500">Ödəniş:</span>
                            <span id="detailBagPayment" class="font-semibold text-green-600">- AZN</span>
                        </div>
                        <div class="pt-3 border-t">
                            <span class="text-slate-500">Qeyd:</span>
                            <p id="detailBagNote" class="text-slate-700 mt-1">-</p>
                        </div>
                    </div>
                </div>

                <!-- Bu kişiye ait tüm kaset kayıtları -->
                <div class="lg:col-span-2 space-y-6">
                    <div class="bg-white rounded-xl border shadow-sm">
                        <div class="px-6 py-4 border-b bg-slate-50 flex justify-between items-center">
                            <h3 class="font-bold text-slate-800">Kaset Tarixçəsi</h3>
                            <span id="bagPersonName" class="text-sm text-slate-500 bg-slate-100 px-3 py-1 rounded-full"></span>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-slate-100">
                                    <tr>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Tarix</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Verilən</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Geri</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Qaytarılmalı</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Borc</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Ödəniş</th>
                                        <th class="text-left px-4 py-2 text-xs font-semibold text-slate-600">Qeyd</th>
                                    </tr>
                                </thead>
                                <tbody id="bagHistory"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Xülasə Kartları -->
                    <div class="grid grid-cols-3 gap-4">
                        <div class="bg-white p-4 rounded-xl border shadow-sm text-center">
                            <div class="text-sm text-slate-500">Ümumi Verilən</div>
                            <div id="totalGiven" class="text-2xl font-bold text-slate-800">0</div>
                        </div>
                        <div class="bg-white p-4 rounded-xl border shadow-sm text-center">
                            <div class="text-sm text-slate-500">Ümumi Qaytarılan</div>
                            <div id="totalReturned" class="text-2xl font-bold text-green-600">0</div>
                        </div>
                        <div class="bg-white p-4 rounded-xl border shadow-sm text-center">
                            <div class="text-sm text-slate-500">Ümumi Borc</div>
                            <div id="totalBagDebt" class="text-2xl font-bold text-red-600">0 AZN</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</MainLayout>

<script is:inline src="/services/bags.js"></script>
