---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Şoför Maaşları">
    <div class="ml-64 min-h-screen bg-slate-50">
        <div class="p-8">
            <div class="flex justify-between items-center mb-6">
                <h1 class="text-2xl font-bold text-slate-800">Şoför Maaşları</h1>
                <button onclick="openDriverModal()" class="bg-cyan-500 text-white px-4 py-2 rounded-lg hover:bg-cyan-600 transition-colors">+ Yeni Maaş</button>
            </div>

            <div id="driverTotalStats" class="text-lg font-semibold text-slate-700 mb-4 bg-white px-4 py-3 rounded-xl border shadow-sm"></div>

            <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-6">
                <div class="lg:col-span-1">
                    <h3 class="text-lg font-bold text-slate-800 mb-3">Şoför Xülasəsi</h3>
                    <div id="driverSummary" class="space-y-2"></div>
                </div>
                <div class="lg:col-span-3 bg-white rounded-xl border shadow-sm overflow-hidden">
                    <table class="w-full">
                        <thead class="bg-slate-100">
                            <tr>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Tarix</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Şoför</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Gündəlik</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Əlavə Reys</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Cəm</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Ödəndi</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Borc</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Qeyd</th>
                                <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Əməliyyat</th>
                            </tr>
                        </thead>
                        <tbody id="driverTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div id="driverModal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-2xl p-6 w-full max-w-lg mx-4 shadow-2xl">
            <h2 id="driverModalTitle" class="text-xl font-bold text-slate-800 mb-4">Yeni Şoför Maaşı</h2>
            <form onsubmit="saveDriver(event)">
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Tarix</label>
                        <input type="date" id="driverDate" class="w-full border rounded-lg px-3 py-2" required>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Şoför Adı</label>
                        <input type="text" id="driverName" class="w-full border rounded-lg px-3 py-2" placeholder="Namiq, Cavid, Tofiq..." required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Gündəlik Maaş</label>
                        <input type="number" step="0.01" id="driverWage" class="w-full border rounded-lg px-3 py-2" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Əlavə Reys</label>
                        <input type="number" step="0.01" id="driverExtra" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Cəm</label>
                        <input type="number" step="0.01" id="driverTotal" class="w-full border rounded-lg px-3 py-2" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Ödəndi</label>
                        <input type="number" step="0.01" id="driverPaid" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Qalıq Borc</label>
                        <input type="number" step="0.01" id="driverDebt" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Qeyd</label>
                        <input type="text" id="driverNote" class="w-full border rounded-lg px-3 py-2">
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" onclick="closeDriverModal()" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg">Ləğv et</button>
                    <button type="submit" class="px-4 py-2 bg-cyan-500 text-white rounded-lg hover:bg-cyan-600">Yadda saxla</button>
                </div>
            </form>
        </div>
    </div>
</MainLayout>

<script is:inline src="/services/driver.js"></script>
