---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Alış Yönetimi">
    <div class="ml-64 min-h-screen">
        <div class="p-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800 tracking-tight italic">Alışlar</h1>
                </div>
                <button
                        onclick="openPurchaseModal()"
                        class="bg-green-500 text-white px-6 py-3 rounded-2xl shadow-lg shadow-green-100 hover:bg-green-600 transition-all active:scale-95 font-bold flex items-center gap-2"
                >
                    <i class='bx bx-cart-add text-2xl'></i> Yeni Alış
                </button>
            </div>

            <div id="purchase-container" class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-20 text-center">
                    <div class="animate-spin inline-block w-10 h-10 border-4 border-green-500 border-t-transparent rounded-full mb-4"></div>
                    <p class="text-slate-400 animate-pulse font-medium">Connecting To Database...</p>
                </div>
            </div>
        </div>
    </div>

    <div id="purchase-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[100] flex items-center justify-center p-4">
        <div class="bg-white rounded-[2.5rem] shadow-2xl w-[60%] overflow-hidden animate-in fade-in zoom-in duration-200 border border-white/20">

            <div class="p-6 border-b border-slate-50 flex justify-between items-center bg-slate-50/50">
                <div>
                    <h3 id="modal-title" class="text-2xl font-black text-slate-800 tracking-tight leading-none">Yeni Alış</h3>
                </div>
                <button onclick="closePurchaseModal()" class="w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-red-50 text-slate-400 hover:text-red-500 transition-all">
                    <i class='bx bx-x text-3xl'></i>
                </button>
            </div>

            <form id="purchase-form" class="p-8 space-y-6">
                <div class="bg-green-50/50 p-6 rounded-[2rem] border border-green-100/50">
                    <div class="mb-6 space-y-2">
                        <label class="text-xs font-black text-slate-500 uppercase ml-1">Müştəri Seç</label>
                        <select id="purchase-customerId" required
                                class="w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-green-500/10 focus:border-green-500 outline-none transition-all appearance-none cursor-pointer font-bold text-slate-700 shadow-sm">
                        </select>
                    </div>

                    <div class="flex items-center gap-2 mb-4 text-green-600">
                        <i class='bx bx-basket text-xl'></i>
                        <span class="text-xs font-black uppercase tracking-wider">Məhsul</span>
                    </div>

                    <div class="flex items-center gap-4 bg-white p-3 mb-3 rounded-[2.5rem] border-2 border-slate-100 shadow-md">
                        <div class="flex-[2.5] relative h-16">
                            <select id="item-product-id"
                                    class="w-full h-full pl-6 pr-10 bg-slate-50 border-2 border-transparent rounded-[1.5rem] text-lg font-black outline-none focus:bg-white focus:border-green-500/20 focus:ring-4 focus:ring-green-500/5 transition-all appearance-none cursor-pointer text-slate-800 flex items-center">
                            </select>
                            <i class='bx bx-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 text-2xl pointer-events-none'></i>
                        </div>

                        <div class="flex-1 h-16">
                            <input type="number" id="item-qty" placeholder="Say"
                                   value="1" min="1" step="1"
                                   class="w-full h-full px-4 bg-slate-50 border-2 border-transparent rounded-[1.5rem] text-lg font-black outline-none focus:bg-white focus:border-green-500/20 focus:ring-4 focus:ring-green-500/5 transition-all text-center placeholder:text-slate-300 text-slate-800" />
                        </div>

                        <div class="flex-1 h-16 relative">
                            <input type="number" id="item-price" placeholder="Qiymet"
                                   class="w-full h-full px-4 bg-slate-50 border-2 border-transparent rounded-[1.5rem] text-lg font-black outline-none focus:bg-white focus:border-green-500/20 focus:ring-4 focus:ring-green-500/5 transition-all placeholder:text-slate-300 text-slate-800" />
                        </div>

                        <button type="button" onclick="addItemToBasket()"
                                class="w-20 h-16 shrink-0 bg-slate-900 text-white rounded-[1.5rem] flex items-center justify-center hover:bg-green-500 shadow-xl shadow-slate-200 hover:shadow-green-200 transition-all duration-300 active:scale-95 group">
                            <i class='bx bx-plus text-4xl font-bold group-hover:rotate-90 transition-transform'></i>
                        </button>
                    </div>

                    <div class="mt-10 overflow-hidden border border-green-100/30 rounded-2xl bg-white/50 shadow-inner">
                        <table class="w-full text-left">
                            <thead class="bg-green-100/20 text-[10px] font-black text-green-400 uppercase tracking-widest">
                            <tr>
                                <th class="px-6 py-3">Ad</th>
                                <th class="px-6 py-3 text-center">Say</th>
                                <th class="px-6 py-3">Tək Qiymət</th>
                                <th class="px-6 py-3">Cəm Qiymət</th>
                                <th class="px-6 py-3 text-right">#</th>
                            </tr>
                            </thead>
                            <tbody id="basket-body" class="divide-y divide-green-50/50">
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="flex items-end justify-between pt-4 bg-white">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider">Cəm Qiymət</p>
                        <div class="flex items-baseline gap-1">
                            <h2 id="total-price-display" class="text-4xl font-black text-slate-800 tabular-nums">0.00</h2>
                            <span class="text-sm font-bold text-green-500 uppercase">azn</span>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <button type="button" onclick="closePurchaseModal()" class="px-8 py-4 rounded-2xl font-bold text-slate-400 hover:bg-slate-100 transition-all duration-200">
                            Cancel
                        </button>
                        <button type="submit" class="px-12 py-4 bg-green-500 text-white rounded-2xl font-black shadow-[0_15px_30px_-10px_rgba(34,197,94,0.4)] hover:bg-green-600 hover:-translate-y-1 active:translate-y-0 transition-all duration-200 flex items-center gap-2">
                            Submit <i class='bx bx-check-double text-xl'></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div id="details-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[110] flex items-center justify-center p-4">
        <div class="bg-white rounded-[2.5rem] shadow-2xl w-[70%] overflow-hidden border border-white/20 animate-in fade-in zoom-in duration-200">
            <div class="p-8 border-b border-slate-50 flex justify-between items-center bg-slate-50/50">
                <div>
                    <h3 class="text-2xl font-black text-slate-800 tracking-tight">Alış Detalları</h3>
                    <p id="details-date" class="text-xs text-slate-400 font-bold mt-1 uppercase tracking-widest"></p>
                </div>
                <button onclick="closeDetailsModal()" class="w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-slate-100 text-slate-400 transition-all">
                    <i class='bx bx-x text-3xl'></i>
                </button>
            </div>

            <div class="p-8 space-y-8">
                <div class="grid grid-cols-3 gap-6">
                    <div class="p-6 bg-green-50 rounded-[1.5rem] border border-green-100">
                        <p class="text-[10px] font-black text-green-400 uppercase mb-1">Müştəri</p>
                        <h4 id="details-customer" class="text-xl font-bold text-slate-800"></h4>
                    </div>
                    <div class="p-6 bg-slate-50 rounded-[1.5rem] border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Cəm Qiymət</p>
                        <h4 id="details-total" class="text-xl font-black text-green-600 italic"></h4>
                    </div>
                    <div class="p-6 bg-slate-50 rounded-[1.5rem] border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Ümumi Çəki</p>
                        <h4 id="details-total-weight" class="text-xl font-black text-slate-600 italic"></h4>
                    </div>
                </div>

                <div class="rounded-3xl border border-slate-100 overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] font-black text-slate-400 uppercase">
                        <tr>
                            <th class="px-6 py-4">Məhsul</th>
                            <th class="px-6 py-4 text-center">Say</th>
                            <th class="px-6 py-4">Tək Qiymət</th>
                            <th class="px-6 py-4 text-right">Cəm Qiymət</th>
                        </tr>
                        </thead>
                        <tbody id="details-items-body" class="divide-y divide-slate-50 text-sm font-bold text-slate-700">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script is:inline src="/services/purchase.js"></script>
</MainLayout>