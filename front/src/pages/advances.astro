---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Avans">
    <div class="ml-64 min-h-screen bg-slate-50">
        <div class="p-8">
            <div class="flex justify-between items-center mb-6">
                <h1 class="text-2xl font-bold text-slate-800">Avans (Tedarikçi Avansları)</h1>
                <button onclick="openAdvanceModal()" class="bg-amber-500 text-white px-4 py-2 rounded-lg hover:bg-amber-600 transition-colors">+ Yeni Avans</button>
            </div>

            <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="bg-white p-4 rounded-xl border shadow-sm">
                    <div class="text-sm text-slate-500">Cəmi Avans</div>
                    <div class="text-2xl font-bold text-slate-800"><span id="totalAdvance">0</span> AZN</div>
                </div>
                <div class="bg-white p-4 rounded-xl border shadow-sm">
                    <div class="text-sm text-slate-500">Ödənən</div>
                    <div class="text-2xl font-bold text-green-600"><span id="paidAdvance">0</span> AZN</div>
                </div>
                <div class="bg-white p-4 rounded-xl border shadow-sm">
                    <div class="text-sm text-slate-500">Qalan Borc</div>
                    <div class="text-2xl font-bold text-red-600"><span id="debtAdvance">0</span> AZN</div>
                </div>
            </div>

            <div class="bg-white rounded-xl border shadow-sm overflow-hidden">
                <table class="w-full">
                    <thead class="bg-slate-100">
                        <tr>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Tarix</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Göndərən</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Alan</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Məbləğ</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Ödədi</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Qalıq Borc</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Qeyd</th>
                            <th class="text-left px-4 py-3 text-sm font-semibold text-slate-600">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody id="advanceTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div id="advanceModal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-2xl p-6 w-full max-w-lg mx-4 shadow-2xl">
            <h2 id="advanceModalTitle" class="text-xl font-bold text-slate-800 mb-4">Yeni Avans</h2>
            <form onsubmit="saveAdvance(event)">
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Tarix</label>
                        <input type="date" id="advanceDate" class="w-full border rounded-lg px-3 py-2" required>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Göndərən</label>
                        <input type="text" id="advanceSender" class="w-full border rounded-lg px-3 py-2" placeholder="Vicat, ..." required>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Alan (Tedarikçi)</label>
                        <input type="text" id="advanceReceiver" class="w-full border rounded-lg px-3 py-2" placeholder="Tedarikçi adı" required>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Bağlı Müştəri (istеğe bağlı)</label>
                        <select id="advanceCustomerId" class="w-full border rounded-lg px-3 py-2"></select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Məbləğ</label>
                        <input type="number" step="0.01" id="advanceAmount" class="w-full border rounded-lg px-3 py-2" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Ödədi</label>
                        <input type="number" step="0.01" id="advancePaid" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Qalıq Borc</label>
                        <input type="number" step="0.01" id="advanceDebt" class="w-full border rounded-lg px-3 py-2">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1">Qeyd</label>
                        <textarea id="advanceNote" class="w-full border rounded-lg px-3 py-2" rows="2"></textarea>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" onclick="closeAdvanceModal()" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg">Ləğv et</button>
                    <button type="submit" class="px-4 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600">Yadda saxla</button>
                </div>
            </form>
        </div>
    </div>
</MainLayout>

<script is:inline src="/services/advance.js"></script>
