---
export const prerender = false;
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="İşçi Detalları">
    <div class="ml-64 min-h-screen bg-slate-50/50">
        <div class="p-8">
            <div class="flex items-center gap-4 mb-8">
                <a href="/employees" class="w-10 h-10 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 transition-all shadow-sm">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                </a>
                <div>
                    <h1 id="det-fullname" class="text-3xl font-bold text-slate-800 tracking-tight">Yüklənir...</h1>
                    <p class="text-slate-500 mt-1 font-medium italic">İşçi profili və maliyyə tarixçəsi</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="space-y-6">
                    <div class="bg-white p-7 rounded-[2rem] shadow-sm border border-slate-200">
                        <h3 class="text-lg font-extrabold text-slate-800 mb-6 flex items-center gap-2">
                            <i data-lucide="user" class="w-5 h-5 text-blue-500"></i>
                            İşçi Kartı
                        </h3>
                        <div class="space-y-5">
                            <div class="bg-slate-50 p-3 rounded-2xl border border-slate-100">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-1">Telefon</label>
                                <p id="det-phone" class="text-slate-700 font-bold text-lg">-</p>
                            </div>
                            <div class="bg-emerald-50/50 p-3 rounded-2xl border border-emerald-100">
                                <label class="text-[10px] font-black text-emerald-500 uppercase tracking-widest block mb-1">Maaş</label>
                                <p id="det-salary" class="text-emerald-700 font-black text-2xl">0 AZN</p>
                            </div>
                            <div class="bg-slate-50 p-3 rounded-2xl border border-slate-100">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-1">Qeydiyyat</label>
                                <p id="det-createdat" class="text-slate-700 font-bold">-</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white p-7 rounded-[2rem] shadow-lg shadow-blue-900/5 border border-blue-100">
                        <h3 class="text-lg font-extrabold text-slate-800 mb-6 flex items-center gap-2">
                            <i data-lucide="wallet" class="w-5 h-5 text-blue-600"></i>
                            Yeni Ödəniş
                        </h3>
                        <form id="salary-form" class="space-y-4">
                            <div class="space-y-1">
                                <label class="text-sm font-bold text-slate-700 ml-1">Ödəniş Tarixi</label>
                                <input type="date" id="sal-date" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 font-medium" />
                            </div>

                            <div class="flex gap-2">
                                <button type="button" onclick="setFastAmount(1)" class="flex-1 py-2 text-xs font-bold bg-slate-100 text-slate-600 rounded-lg hover:bg-blue-600 hover:text-white transition-all">Tam Maaş</button>
                                <button type="button" onclick="setFastAmount(0.5)" class="flex-1 py-2 text-xs font-bold bg-slate-100 text-slate-600 rounded-lg hover:bg-blue-600 hover:text-white transition-all">50% Avans</button>
                            </div>

                            <div class="space-y-1">
                                <label class="text-sm font-bold text-slate-700 ml-1">Məbləğ (AZN)</label>
                                <input type="number" id="sal-amount" required step="0.01" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 font-bold text-lg" placeholder="0.00" />
                            </div>

                            <div class="space-y-1">
                                <label class="text-sm font-bold text-slate-700 ml-1">Açıqlama</label>
                                <textarea id="sal-comment" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 transition-all" rows="2" placeholder="Qeyd yazın..."></textarea>
                            </div>

                            <button type="submit" class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black shadow-xl shadow-blue-200 hover:bg-blue-700 transition-all">Təsdiqlə</button>
                        </form>
                    </div>
                </div>

                <div class="lg:col-span-2">
                    <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 overflow-hidden min-h-[500px]">
                        <div class="p-6 border-b border-slate-50 bg-slate-50/30">
                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                <h3 class="text-lg font-extrabold text-slate-800">Ödəniş Tarixçəsi</h3>
                                <div class="flex items-center gap-2">
                                    <input type="date" id="filter-start" class="px-3 py-2 border rounded-xl text-sm outline-none focus:border-blue-500" />
                                    <span class="text-slate-400">-</span>
                                    <input type="date" id="filter-end" class="px-3 py-2 border rounded-xl text-sm outline-none focus:border-blue-500" />
                                    <button onclick="applyFilters()" class="py-2 px-4 bg-blue-600 text-white rounded-xl hover:bg-blue-700 flex items-center gap-2 text-sm font-bold">
                                        <i data-lucide="search" class="w-4 h-4"></i> Filtr
                                    </button>
                                </div>
                            </div>
                            <div class="mt-4 flex justify-end">
                                <span id="total-paid" class="px-4 py-2 bg-emerald-100 text-emerald-700 rounded-full text-sm font-black italic shadow-sm">Cəmi: 0 AZN</span>
                            </div>
                        </div>
                        <div id="salary-history-container" class="p-2"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline src="/services/employee.js"></script>
</MainLayout>